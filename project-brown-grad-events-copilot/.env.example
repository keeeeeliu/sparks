# Copy to .env and fill in. Never commit .env.

# Pick a provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# Model used for extraction + enrichment (override as you like)
LLM_MODEL=gpt-4o-mini

# Streamlit UI loads .env from project root automatically

# Provider keys (only the one you use is required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
